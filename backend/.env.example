# =============================================
# GitExplorer Backend - Environment Variables
# =============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# MongoDB connection string
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/gitexplorer

# Express session secret (any random string)
SESSION_SECRET=your_random_secret_here_change_this

# GitHub OAuth App credentials
# Create one at: https://github.com/settings/developers → OAuth Apps → New OAuth App
# Homepage URL:      http://localhost:5173
# Callback URL:      http://localhost:5000/api/auth/github/callback
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# GitHub Personal Access Token (for fetching repos)
# Create at: https://github.com/settings/tokens → Generate new token (classic)
# Scopes needed: read:user, repo
GITHUB_API_KEY=your_github_personal_access_token

# The callback URL registered in your GitHub OAuth App
GITHUB_CALLBACK_URL=http://localhost:5000/api/auth/github/callback

# URL of your frontend (for CORS)
CLIENT_BASE_URL=http://localhost:5173

# Server port
PORT=5000
